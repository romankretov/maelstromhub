{
  "name": "maelstromhub",
  "version": "0.1.0",
  "private": true,
  "description": "A streamlined quant trading and research suite for Hyperliquid.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:web": "npm --workspace apps/web run dev",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "format": "prettier --write .",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --remove-orphans"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
